        <div class="edu-degree">B.E. / B.Tech — Computer Science</div>
        <div class="edu-school">Your College Name, Coimbatore</div>
        <div class="edu-grade">CGPA: X.X / 10</div>
      </div>
      <div class="edu-item">
        <div class="edu-dot"></div>
        <div class="edu-year">2022 — 2024</div>
        <div class="edu-degree">Higher Secondary Certificate (HSC)</div>
        <div class="edu-school">Your School Name</div>
        <div class="edu-grade">Score: XX%</div>
      </div>
      <div class="edu-item">
        <div class="edu-dot"></div>
